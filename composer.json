{
  "name": "packages/form-builder",
  "description": "Form Builder package for Laravel (multi-tenant, schema-driven forms).",
  "version": "0.1.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0",
    "spatie/laravel-data": "^4.17",
    "opis/json-schema": "^2.4"
  },
  "autoload": {
    "psr-4": {
      "Packages\\FormBuilder\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Packages\\FormBuilder\\Tests\\": "tests/",
      "Packages\\FormBuilder\\Database\\Factories\\": "database/factories/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "orchestra/testbench": "^10.6",
    "pestphp/pest": "^4.1"
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Packages\\FormBuilder\\FormBuilderServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
